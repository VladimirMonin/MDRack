{
  "$id": "https://mdrack.invalid/schemas/evaluation/corpus-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract": {"const": "mdrack.evaluation-corpus"},
    "schema_version": {"const": 1},
    "corpus_id": {"pattern": "^corpus_[0-9a-f]{32}$", "type": "string"},
    "corpus_version": {"minLength": 1, "type": "string"},
    "source_namespace": {"minLength": 1, "type": "string"},
    "contract_digest": {"pattern": "^sha256:[0-9a-f]{64}$", "type": "string"},
    "query_set_ref": {
      "additionalProperties": false,
      "properties": {
        "path": {"minLength": 1, "type": "string"},
        "contract": {"const": "mdrack.evaluation-queries"},
        "schema_version": {"const": 1}
      },
      "required": ["path", "contract", "schema_version"],
      "type": "object"
    },
    "policy_refs": {
      "additionalProperties": false,
      "properties": {
        "builder": {"$ref": "#/$defs/digest"},
        "parser": {"$ref": "#/$defs/digest"},
        "chunker": {"$ref": "#/$defs/digest"},
        "vector_profile": {"$ref": "#/$defs/digest"}
      },
      "required": ["builder", "parser", "chunker", "vector_profile"],
      "type": "object"
    },
    "roadmap_scale": {"$ref": "#/$defs/scale"},
    "resources": {
      "items": {"$ref": "#/$defs/resource"},
      "minItems": 50,
      "type": "array"
    }
  },
  "required": ["contract", "schema_version", "corpus_id", "corpus_version", "source_namespace", "contract_digest", "query_set_ref", "policy_refs", "roadmap_scale", "resources"],
  "type": "object",
  "$defs": {
    "digest": {"pattern": "^sha256:[0-9a-f]{64}$", "type": "string"},
    "resource_id": {"pattern": "^res_[0-9a-f]{32}$", "type": "string"},
    "unit_id": {"pattern": "^unit_[0-9a-f]{32}$", "type": "string"},
    "frame_id": {"pattern": "^frame_[0-9a-f]{32}$", "type": "string"},
    "counts": {
      "additionalProperties": false,
      "properties": {
        "document": {"minimum": 20, "type": "integer"},
        "image": {"minimum": 10, "type": "integer"},
        "audio": {"minimum": 10, "type": "integer"},
        "video": {"minimum": 10, "type": "integer"},
        "videos_with_frames": {"minimum": 5, "type": "integer"}
      },
      "required": ["document", "image", "audio", "video", "videos_with_frames"],
      "type": "object"
    },
    "scale": {
      "additionalProperties": false,
      "properties": {
        "status": {"const": "satisfied"},
        "required": {"$ref": "#/$defs/counts"},
        "actual": {"$ref": "#/$defs/counts"}
      },
      "required": ["status", "required", "actual"],
      "type": "object"
    },
    "provenance": {
      "additionalProperties": false,
      "properties": {
        "classification": {"enum": ["synthetic", "licensed", "deidentified"]},
        "license_spdx": {
          "pattern": "^(?:\\s|\\(|\\)|AND|OR|Apache-2\\.0|BSD-2-Clause|BSD-3-Clause|CC-BY-4\\.0|CC-BY-SA-4\\.0|CC0-1\\.0|MIT)+$",
          "type": "string"
        },
        "origin": {"minLength": 1, "type": "string"},
        "pii_status": {"const": "reviewed_no_pii"},
        "publishable": {"const": true}
      },
      "required": ["classification", "license_spdx", "origin", "pii_status", "publishable"],
      "type": "object"
    },
    "unit": {
      "additionalProperties": false,
      "properties": {
        "unit_id": {"$ref": "#/$defs/unit_id"},
        "unit_kind": {"enum": ["text_chunk", "time_segment", "frame", "whole_resource"]},
        "representation_kind": {"enum": ["retrieval_text", "ocr_text", "caption_text", "audio_transcript", "frame_caption"]},
        "ordinal": {"minimum": 0, "type": "integer"},
        "start_ms": {"minimum": 0, "type": "integer"},
        "end_ms": {"minimum": 1, "type": "integer"},
        "timestamp_ms": {"minimum": 0, "type": "integer"},
        "frame_id": {"$ref": "#/$defs/frame_id"}
      },
      "required": ["unit_id", "unit_kind", "representation_kind", "ordinal"],
      "type": "object"
    },
    "resource": {
      "additionalProperties": false,
      "properties": {
        "resource_id": {"$ref": "#/$defs/resource_id"},
        "resource_kind": {"enum": ["document", "image", "audio", "video"]},
        "media_type": {"minLength": 1, "type": "string"},
        "source_namespace": {"minLength": 1, "type": "string"},
        "artifact_ref": {"minLength": 1, "type": "string"},
        "artifact_sha256": {"$ref": "#/$defs/digest"},
        "content_sha256": {"$ref": "#/$defs/digest"},
        "representations": {"items": {"type": "string"}, "minItems": 1, "type": "array", "uniqueItems": true},
        "units": {"items": {"$ref": "#/$defs/unit"}, "minItems": 1, "type": "array"},
        "provenance": {"$ref": "#/$defs/provenance"}
      },
      "required": ["resource_id", "resource_kind", "media_type", "source_namespace", "artifact_ref", "artifact_sha256", "content_sha256", "representations", "units", "provenance"],
      "type": "object"
    }
  }
}
